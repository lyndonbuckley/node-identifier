{
    "name": "node-identifier",
    "version": "1.4.1",
    "description": " A Node.js/TypeScript helper for object/entity identifiers",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "tsc",
        "format": "prettier --write \"src/**/*.ts\"",
        "lint": "tslint -p tsconfig.json",
        "prepare": "npm run build",
        "prepublishOnly": "npm run lint",
        "preversion": "npm run lint",
        "version": "npm run format && git add -A src",
        "postversion": "git push && git push --tags"
    },
    "files": [
        "lib/**/*"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lyndonbuckley/node-identifier.git"
    },
    "keywords": [
        "node",
        "unique",
        "identifier",
        "id",
        "generator"
    ],
    "author": "Lyndon Buckley <npm@lyndonbuckley.com>",
    "license": "GPL-3.0-or-later",
    "bugs": {
        "url": "https://github.com/lyndonbuckley/node-identifier/issues"
    },
    "homepage": "https://github.com/lyndonbuckley/node-identifier#readme",
    "devDependencies": {
        "@types/node": "^25.9.2",
        "prettier": "^3.8.4",
        "tslint": "^6.1.3",
        "tslint-config-prettier": "^1.18.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "base-x": "^5.0.1",
        "uuid": "^14.0.0"
    }
}
